{
  "entities": {
    "Tenant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tenant",
      "type": "object",
      "description": "Represents a tenant (e.g., a gym or training center) within the application.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the tenant." },
        "name": { "type": "string", "description": "The name of the tenant." },
        "members": {
          "type": "object",
          "description": "A map of user UIDs to their roles within the tenant (e.g., 'owner', 'member')."
        }
      },
      "required": ["id", "name", "members"]
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile information within a tenant.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the user (matches auth UID)." },
        "tenantId": { "type": "string", "description": "Reference to the parent Tenant." },
        "firstName": { "type": "string", "description": "The first name of the user." },
        "lastName": { "type": "string", "description": "The last name of the user." },
        "email": { "type": "string", "format": "email", "description": "Primary authentication email." },
        "secondaryEmail": { "type": "string", "format": "email", "description": "An optional secondary email for the user." },
        "phoneNumber": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "avatarHint": { "type": "string" },
        "joinDate": { "type": "string", "format": "date" },
        "currentPlan": { "type": "string" },
        "planType": { "type": "string", "description": "The type of training plan assigned to the user." },
        "progress": { "type": "number" },
        "trainingDays": { "type": "array", "items": { "type": "string" } },
        "objective": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "occupation": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "address": { "type": "string" },
        "cuit": { "type": "string" },
        "linkedinUrl": { "type": "string", "format": "uri" },
        "instagramUrl": { "type": "string", "format": "uri" },
        "xUrl": { "type": "string", "format": "uri" },
        "whatsapp": { "type": "string" },
        "careerExperience": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "company": { "type": "string" },
              "startDate": { "type": "string", "format": "date" },
              "endDate": { "type": "string", "format": "date" },
              "description": { "type": "string" }
            }
          }
        },
        "education": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "institution": { "type": "string" },
              "degree": { "type": "string" },
              "fieldOfStudy": { "type": "string" },
              "startDate": { "type": "string", "format": "date" },
              "endDate": { "type": "string", "format": "date" }
            }
          }
        }
      },
      "required": ["id", "tenantId", "firstName", "lastName", "email"]
    },
    "MedicalHistory": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Medical History",
      "type": "object",
      "description": "A snapshot of a user's medical information at a specific point in time.",
      "properties": {
        "id": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "medicalClearance": { "type": "boolean", "description": "Indicates if the user has medical clearance to exercise." },
        "bloodType": { "type": "string", "enum": ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"], "description": "The user's blood type." },
        "currentConditions": { "type": "array", "items": { "type": "string" }, "description": "Any current medical conditions." },
        "underMedicalTreatment": { "type": "boolean", "description": "Indicates if the user is currently under medical treatment." },
        "currentMedications": { "type": "array", "items": { "type": "string" }, "description": "A list of current medications." },
        "preexistingInjuries": { "type": "array", "items": { "type": "string" }, "description": "A list of known preexisting injuries." },
        "previousSurgeries": { "type": "array", "items": { "type": "string" }, "description": "A list of previous surgeries." },
        "chronicPain": { "type": "boolean", "description": "Indicates if the user suffers from chronic pain." },
        "medicalRestrictions": { "type": "array", "items": { "type": "string" }, "description": "Any medical restrictions for physical activity." },
        "emergencyContact": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" }
          },
          "description": "The user's emergency contact information."
        }
      },
       "required": ["id", "createdAt"]
    },
    "Biomechanics": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Biomechanics",
      "type": "object",
      "description": "A snapshot of a user's biomechanical assessment at a specific point in time.",
      "properties": {
        "id": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "weight": { "type": "number", "description": "Body weight in kg." },
        "height": { "type": "number", "description": "Height in meters." },
        "bmi": { "type": "number", "description": "Body Mass Index (kg/m²)." },
        "ankleDorsiflexion": { "type": "number", "description": "Ankle dorsiflexion mobility in degrees." },
        "hipMobility": { "type": "number", "description": "Hip mobility (flexion/rotation) in degrees." },
        "shoulderMobility": { "type": "number", "description": "Functional shoulder range of motion in degrees." },
        "coreStability": { "type": "number", "description": "Core stability test (e.g., plank) duration in seconds." },
        "hipStability": { "type": "number", "description": "Unilateral hip stability test score (e.g., 0-5)." },
        "squatPattern": { "type": "number", "description": "Squat pattern technical evaluation score (e.g., 0-5)." },
        "hipHingePattern": { "type": "number", "description": "Hip hinge pattern technical evaluation score (e.g., 0-5)." },
        "relativeStrengthLower": { "type": "number", "description": "Normalized lower body relative strength (kg lifted / body weight)." },
        "relativeStrengthUpper": { "type": "number", "description": "Normalized upper body relative strength (kg lifted / body weight)." },
        "unilateralBalance": { "type": "number", "description": "Unilateral balance test duration in seconds." },
        "asymmetries": { "type": "number", "description": "Right-left strength or mobility difference percentage." },
        "movementPain": { "type": "number", "description": "Self-reported pain during movement on a 0-10 scale." }
      },
      "required": ["id", "createdAt", "weight", "height"]
    },
    "Note": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Note",
      "type": "object",
      "description": "A note about a client, written by a coach.",
      "properties": {
        "id": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "coachName": { "type": "string" },
        "coachAvatarUrl": { "type": "string", "format": "uri" },
        "content": { "type": "string" }
      },
      "required": ["id", "createdAt", "coachName", "content"]
    },
    "Exercise": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Exercise",
      "type": "object",
      "description": "Represents a single fitness exercise in the library.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Cardio", "Fuerza", "Pylo", "Movilidad", "Core"] },
        "equipment": { "type": "string" },
        "difficulty": { "type": "string" },
        "instructions": { "type": "string" },
        "muscleGroups": { "type": "array", "items": { "type": "string" } },
        "videoUrl": { "type": "string", "format": "uri" },
        "imageUrl": { "type": "string", "format": "uri" }
      },
      "required": ["id", "name", "equipment"]
    },
    "Mesocycle": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Mesocycle",
      "type": "object",
      "description": "A structured training plan for a client over a specific month (a mesocycle).",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "year": { "type": "number" },
        "month": { "type": "number" },
        "weeks": {
          "type": "object",
          "description": "Contains the plan for each week of the month.",
          "additionalProperties": {
            "type": "object",
            "description": "Contains the plan for each day of the week.",
             "additionalProperties": {
                "type": "object",
                "properties": {
                    "focus": { "type": "string" },
                    "isRestDay": { "type": "boolean" },
                    "exercises": {
                        "type": "array",
                        "items": { "$ref": "#/entities/PlannedExercise" }
                    }
                }
             }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "clientId", "year", "month", "weeks"]
    },
    "PlannedExercise": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Planned Exercise",
        "type": "object",
        "description": "An exercise within a workout plan, including specific parameters.",
        "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "imageUrl": { "type": "string", "format": "uri" },
            "muscleGroups": { "type": "array", "items": { "type": "string" } },
            "sets": { "type": "string" },
            "reps": { "type": "string" },
            "rpe": { "type": "string" },
            "rest": { "type": "string" },
            "duration": { "type": "string" }
        },
        "required": ["id", "name"]
    },
    "ServicePlan": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Service Plan",
      "type": "object",
      "description": "Defines a commercial service plan offered by the coach.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string", "enum": ["usd", "eur", "ars"] },
        "frequency": { "type": "string", "enum": ["weekly", "monthly", "quarterly", "semiannually", "annually", "once"] },
        "hasPromo": { "type": "boolean" },
        "promoType": { "type": "string", "enum": ["percentage", "fixed"] },
        "promoValue": { "type": "number" },
        "promoDuration": { "type": "string", "enum": ["indefinite", "first_month", "custom"] },
        "promoMonths": { "type": "number" },
        "benefits": { "type": "array", "items": { "type": "object", "properties": { "text": { "type": "string" } } } }
      },
      "required": ["id", "name", "price", "currency", "frequency"]
    },
    "ClientPlan": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Client Plan",
        "type": "object",
        "description": "Represents an assigned commercial plan for a specific client.",
        "properties": {
            "id": { "type": "string" },
            "clientId": { "type": "string" },
            "servicePlanId": { "type": "string" },
            "trainingDays": { "type": "array", "items": { "type": "string" } },
            "hoursPerClass": { "type": "number" },
            "monthlyCost": { "type": "number" },
            "paymentMethod": { "type": "string", "enum": ["cash", "card", "transfer"] },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "clientId", "servicePlanId", "trainingDays", "monthlyCost", "paymentMethod", "createdAt"]
    },
    "Payment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Payment",
      "type": "object",
      "description": "Represents a single payment transaction for a client's plan.",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientPlanId": { "type": "string" },
        "servicePlanId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"] }
      },
      "required": ["id", "clientId", "clientPlanId", "amount", "paymentDate", "status"]
    },
    "Settings": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Settings",
      "type": "object",
      "description": "Stores user-specific application settings.",
      "properties": {
        "units": { "type": "string", "enum": ["metric", "imperial"] },
        "theme": { "type": "string", "enum": ["light", "dark", "system"] },
        "currency": { "type": "string" },
        "language": { "type": "string", "enum": ["es", "en"] },
        "location": { "type": "string" },
        "workingDays": { "type": "array", "items": { "type": "string" } },
        "startTime": { "type": "string", "format": "time" },
        "endTime": { "type": "string", "format": "time" },
        "googleCalendarSync": { "type": "boolean" }
      },
      "required": ["units", "theme", "currency", "language", "workingDays", "startTime", "endTime", "googleCalendarSync"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/tenants/{tenantId}",
        "definition": { "schema": { "$ref": "#/entities/Tenant" }, "description": "Stores tenant data." }
      },
      {
        "path": "/tenants/{tenantId}/user_profile/{userId}",
        "definition": { "schema": { "$ref": "#/entities/UserProfile" }, "description": "Stores user profiles for a tenant." }
      },
      {
        "path": "/tenants/{tenantId}/user_profile/{userId}/medicalHistory/{historyId}",
        "definition": { "schema": { "$ref": "#/entities/MedicalHistory" }, "description": "Stores timestamped medical history records for a user." }
      },
      {
        "path": "/tenants/{tenantId}/user_profile/{userId}/biomechanics/{biomechanicsId}",
        "definition": { "schema": { "$ref": "#/entities/Biomechanics" }, "description": "Stores timestamped biomechanical assessments for a user." }
      },
      {
        "path": "/tenants/{tenantId}/user_profile/{userId}/notes/{noteId}",
        "definition": { "schema": { "$ref": "#/entities/Note" }, "description": "Stores coach's notes for a user." }
      },
      {
        "path": "/tenants/{tenantId}/exercises/{exerciseId}",
        "definition": { "schema": { "$ref": "#/entities/Exercise" }, "description": "Stores the exercise library for a tenant." }
      },
      {
        "path": "/tenants/{tenantId}/mesocycles/{mesocycleId}",
        "definition": { "schema": { "$ref": "#/entities/Mesocycle" }, "description": "Stores training plans for clients." }
      },
       {
        "path": "/tenants/{tenantId}/services/{serviceId}",
        "definition": { "schema": { "$ref": "#/entities/ServicePlan" }, "description": "Stores the service plans offered by a tenant." }
      },
      {
        "path": "/tenants/{tenantId}/client_plans/{planId}",
        "definition": { "schema": { "$ref": "#/entities/ClientPlan" }, "description": "Stores the commercial plans assigned to clients." }
      },
      {
        "path": "/tenants/{tenantId}/payments/{paymentId}",
        "definition": { "schema": { "$ref": "#/entities/Payment" }, "description": "Stores individual payment transactions for clients." }
      },
      {
        "path": "/tenants/{tenantId}/settings/preferences",
        "definition": { "schema": { "$ref": "#/entities/Settings" }, "description": "Stores application settings for a tenant." }
      }
    ]
  }
}
