
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // New Global User Profile
    match /users/{userId} {
      allow read, write: if isSelf(userId);
      // Allow reading profile if it's the tenant or client linked?
      allow read: if isSignedIn(); 
    }

    // Tenant Data
    match /tenants/{tenantId} {
        allow read: if isSignedIn();
        allow write: if isSelf(tenantId); // Basic owner check, refine later

        // Tenant Owner Access to EVERYTHING under tenant
        match /{document=**} {
           allow read, write: if isSelf(tenantId);
        }

       // Client Data in subcollection
       match /clients/{clientId} {
          allow read, write: if isSelf(tenantId); 
          allow read: if isSignedIn() && (
             resource.data.email == request.auth.token.email || 
             resource.data.userId == request.auth.uid ||
             resource.data.id == request.auth.uid 
          );
       }

       // Events Access
       match /events/{eventId} {
           // Owner has full access
           allow read, write: if isSelf(tenantId);
           
           // Client can read if their Auth UID is in the 'uids' array
           // This requires events to have a 'uids' field containing [client.userId]
           allow read: if isSignedIn() && request.auth.uid in resource.data.uids;
       }
    }
    
    // Legacy support (optional, can remove)
    match /user_profile/{userId} {
      allow read, write: if isSelf(userId);
    }
  }
}
