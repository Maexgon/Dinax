/**
 * This ruleset enforces a multi-tenant security model for a SaaS application.
 *
 * Core Philosophy:
 * Access is strictly scoped by tenant membership. All user data is nested within
 * a tenant, and a user must be a member of that tenant to access any of its
 * resources. This creates strong data isolation between different tenants.
 *
 * Denormalization for Authorization:
 * To ensure fast and secure authorization, a `members` map is denormalized directly
 * onto each `/tenants/{tenantId}` document. This map stores user UIDs as keys and
 * their roles (e.g., 'owner') as values. This avoids slow and costly lookups,
 * allowing rules on subcollections like `/users` to quickly verify a user's
 * tenant membership by performing a single `get()` on the parent tenant document.
 * Example: `members: { 'user_abc': 'owner', 'user_xyz': 'member' }`
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to abstract and reuse logic.
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getTenantDoc(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId));
    }

    function isTenantMember(tenantId) {
      let tenantDoc = getTenantDoc(tenantId);
      // Ensure the document exists and the members map has the user's UID.
      return isSignedIn() 
        && tenantDoc.data.members != null
        && request.auth.uid in tenantDoc.data.members;
    }
    
    function isTenantOwner(tenantId) {
      let tenantDoc = getTenantDoc(tenantId);
      // Ensure the doc exists, members map exists, and the user's role is 'owner'.
      return isSignedIn() 
        && tenantDoc.data.members != null
        && tenantDoc.data.members[request.auth.uid] == 'owner';
    }

    match /tenants/{tenantId} {
      allow get: if isTenantMember(tenantId);
      allow list: if false; // Disallow listing all tenants for security.
      // Allow create only if the user is creating their own tenant and is the sole owner.
      allow create: if isSignedIn() 
                    && request.auth.uid == tenantId
                    && request.resource.data.members[request.auth.uid] == 'owner' 
                    && request.resource.data.members.size() == 1 
                    && request.resource.data.id == tenantId;
      // Allow update only if the user is the owner and isn't removing themselves as owner.
      allow update: if isTenantOwner(tenantId) 
                    && request.resource.data.id == resource.data.id 
                    && request.resource.data.members[request.auth.uid] == 'owner';
      allow delete: if isTenantOwner(tenantId);
    }

    match /tenants/{tenantId}/users/{userId} {
      allow get: if isTenantMember(tenantId);
      allow list: if isTenantMember(tenantId);
      // Allow user creation only by a tenant owner.
      allow create: if isTenantOwner(tenantId) 
                    && request.resource.data.id == userId 
                    && request.resource.data.tenantId == tenantId;
      // Allow update by the user themselves or the tenant owner.
      allow update: if isTenantMember(tenantId) && (isSelf(userId) || isTenantOwner(tenantId));
      // Allow delete by the user themselves or the tenant owner.
      allow delete: if isTenantMember(tenantId) && (isSelf(userId) || isTenantOwner(tenantId));
      
      // Rules for subcollections. Access is granted if the user is a member of the parent tenant.
      match /medicalHistory/{historyId} {
        allow read, list: if isTenantMember(tenantId);
        allow write: if isTenantOwner(tenantId);
      }

      match /biomechanics/{biomechanicsId} {
        allow read, list: if isTenantMember(tenantId);
        allow write: if isTenantOwner(tenantId);
      }

      match /notes/{noteId} {
        allow read, list: if isTenantMember(tenantId);
        allow write: if isTenantOwner(tenantId);
      }
    }
  }
}
