/**
 * This ruleset enforces a multi-tenant security model for a SaaS application.
 *
 * Core Philosophy:
 * Access is strictly scoped by tenant membership, which is determined by a
 * custom claim on the user's authentication token. This is a highly secure
 * and efficient model that avoids extra database reads (`get` calls) in rules.
 *
 * Authorization via Custom Claims:
 * When a user is created, a custom claim `tenantId` is set on their auth token.
 * This claim is sent with every authenticated request, allowing rules to instantly
 * verify which tenant the user belongs to by checking `request.auth.token.tenantId`.
 * This is faster and more reliable than using `get()` to check a "members" map.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the request is from the user themselves.
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper function to verify if the user belongs to the specified tenant.
    // It reads the `tenantId` directly from the user's authentication token.
    function isTenantMember(tenantId) {
      return isSignedIn() && request.auth.token.tenantId == tenantId;
    }

    // A user is a tenant owner if they are a member and their UID matches the tenantId.
    // This assumes a 1-to-1 relationship where the tenant creator is the owner.
    function isTenantOwner(tenantId) {
      return isTenantMember(tenantId) && request.auth.uid == tenantId;
    }

    match /tenants/{tenantId} {
      // Allow a user to read their own tenant document.
      allow get: if isTenantMember(tenantId);
      
      // Disallow listing all tenants for security.
      allow list: if false;

      // Allow a user to create their own tenant document.
      // The `tenantId` in the path MUST match the user's UID.
      allow create: if isTenantOwner(tenantId) && request.resource.data.id == tenantId;

      // Allow a tenant owner to update their own tenant document.
      allow update: if isTenantOwner(tenantId) && request.resource.data.id == resource.data.id;

      // Allow a tenant owner to delete their tenant.
      allow delete: if isTenantOwner(tenantId);

      // Subcollections for the tenant.
      match /users/{userId} {
        // Allow a tenant member to get any user profile within their tenant.
        allow get: if isTenantMember(tenantId);
        
        // Allow a tenant member to list all users within their tenant.
        allow list: if isTenantMember(tenantId);

        // Allow a tenant owner to create new users in their tenant.
        allow create: if isTenantOwner(tenantId) && request.resource.data.tenantId == tenantId;
        
        // Allow a user to update their own profile, or an owner to update any profile.
        allow update: if isTenantMember(tenantId) && (isSelf(userId) || isTenantOwner(tenantId));
        
        // Allow a user to delete their own profile, or an owner to delete any profile.
        allow delete: if isTenantMember(tenantId) && (isSelf(userId) || isTenantOwner(tenantId));
        
        // Rules for subcollections of a user. Access is granted if the user is a member of the parent tenant.
        match /medicalHistory/{historyId} {
          allow read, list: if isTenantMember(tenantId);
          allow write: if isTenantOwner(tenantId);
        }

        match /biomechanics/{biomechanicsId} {
          allow read, list: if isTenantMember(tenantId);
          allow write: if isTenantOwner(tenantId);
        }

        match /notes/{noteId} {
          allow read, list: if isTenantMember(tenantId);
          allow write: if isTenantOwner(tenantId);
        }
      }
    }
  }
}
