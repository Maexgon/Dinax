
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to check if the request is from the user themselves.
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Secure helper function to check if the user is an owner of the specified tenant.
    function isTenantOwner(tenantId) {
       return isSignedIn() && get(/databases/$(database)/documents/tenants/$(tenantId)).data.members[request.auth.uid] == 'owner';
    }

    match /tenants/{tenantId} {
      // Allow a user to read their own tenant document if they are the owner.
      allow get: if isTenantOwner(tenantId);
      
      // Disallow listing all tenants for security.
      allow list: if false;

      // Allow a user to create their own tenant document.
      // The `tenantId` in the path MUST match the user's UID, and they must be marked as owner.
      allow create: if isSelf(tenantId) && request.resource.data.members[request.auth.uid] == 'owner';

      // Allow a tenant owner to update their own tenant document.
      allow update, delete: if isTenantOwner(tenantId);

      // Allow tenant owners to manage user profiles within their tenant.
      match /user_profile/{userId} {
        allow read, write: if isTenantOwner(tenantId);

        // This rule allows the tenant owner to manage all subcollections for their clients.
        match /{subcollection}/{docId=**} {
          allow read, write: if isTenantOwner(tenantId);
        }
      }
      
      // Allow tenant owners to manage exercises within their tenant.
      match /exercises/{exerciseId} {
        allow read, write: if isTenantOwner(tenantId);
      }
    }
    
    match /user_profile/{userId} {
      // A user can read and write their own profile (the coach's profile).
      allow read, write: if isSelf(userId);
    }
  }
}
