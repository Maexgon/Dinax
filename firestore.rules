
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to check if the request is from the user themselves.
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /tenants/{tenantId} {
      // A user can read their own tenant document if they are the owner.
      allow get: if isSelf(tenantId);
      
      // Disallow listing all tenants for security.
      allow list: if false;

      // Allow a user to create their own tenant document.
      // The `tenantId` in the path MUST match the user's UID, and they must be marked as owner.
      allow create: if isSelf(tenantId) && request.resource.data.members[request.auth.uid] == 'owner';

      // Allow a tenant owner to update their own tenant document.
      allow update, delete: if isSelf(tenantId);

      // Allow a tenant owner (coach) to create, read, update, and delete profiles for their clients
      // within their own tenant structure.
      match /user_profile/{userId} {
        allow read, write: if isSignedIn() && request.auth.uid == tenantId;
      }
    }
    
    match /user_profile/{userId} {
      // A user can read and write their own profile (the coach's profile).
      allow read, write: if isSelf(userId);
    }
  }
}
